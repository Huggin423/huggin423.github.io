---
const menuItems = [
  { name: 'Home', href: '/' },
  { name: 'Paper Notes', href: '/category/Paper Notes' },
  { name: 'Tech Talk', href: '/category/Tech Talk' },
  { name: 'Fun Products', href: '/category/Fun Products' },
  { name: 'Hobbies', href: '/category/Hobbies' },
];
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-cyber-void/90 border-b border-cyber-cyan/30">
  <nav class="container mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <a href="/" class="text-2xl font-display font-bold text-cyber-cyan hover:text-cyber-purple transition-all uppercase tracking-wider text-glow-cyan">
        <span class="inline-block hover:animate-flicker">⚡</span> Huggin's Tech Nexus
      </a>
      
      <ul class="hidden md:flex space-x-1">
        {menuItems.map((item) => (
          <li>
            <a 
              href={item.href}
              class="px-4 py-2 border border-transparent hover:border-cyber-cyan hover:shadow-neon-cyan transition-all text-gray-300 hover:text-cyber-cyan font-mono text-sm uppercase tracking-wide"
            >
              &gt; {item.name}
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile menu button -->
      <button id="mobile-menu-button" class="md:hidden p-2 border border-cyber-cyan/50 hover:border-cyber-cyan hover:shadow-neon-cyan transition-all">
        <svg class="w-6 h-6 text-cyber-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-2">
      <ul class="space-y-2">
        {menuItems.map((item) => (
          <li>
            <a 
              href={item.href}
              class="block px-4 py-2 border border-cyber-cyan/30 hover:border-cyber-cyan hover:bg-cyber-slate/50 hover:shadow-neon-cyan transition-all text-gray-300 hover:text-cyber-cyan font-mono"
            >
              &gt; {item.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  
  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
