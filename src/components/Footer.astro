---
const currentYear = new Date().getFullYear();
---

<footer class="mt-20 backdrop-blur-md bg-cyber-void/90 border-t border-cyber-purple/30">
  <div class="container mx-auto px-6 py-8">
    <div class="text-center">
      <p class="text-gray-400 mb-2 font-mono">
        Built with <span class="text-cyber-cyan animate-flicker inline-block">&lt;/&gt;</span> and <span class="text-cyber-purple">ASTRO</span>
      </p>
      <p class="text-sm text-gray-500 font-mono">
        <span class="text-cyber-cyan">&copy;</span> {currentYear} <span class="text-cyber-purple">Huggin's Tech Nexus</span> // ALL RIGHTS RESERVED
      </p>
      <div class="mt-4 flex justify-center items-center gap-2 text-xs text-gray-600 font-mono">
        <span class="w-2 h-2 bg-cyber-green rounded-full animate-pulse"></span>
        <span>SYSTEM ONLINE</span>
      </div>
    </div>
  </div>
</footer>
