---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  coverImage?: string;
  tags: string[];
  category: string;
  slug: string;
}

const { title, description, pubDate, coverImage, tags, category, slug } = Astro.props;

const categoryColors: Record<string, string> = {
  'Paper Notes': 'bg-blue-100 text-blue-700',
  'Tech Talk': 'bg-purple-100 text-purple-700',
  'Fun Products': 'bg-pink-100 text-pink-700',
  'Hobbies': 'bg-green-100 text-green-700',
};

const formattedDate = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(pubDate);
---

<article class="group bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
  {coverImage && (
    <div class="relative h-48 overflow-hidden">
      <img 
        src={coverImage} 
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
      <div class="absolute top-4 right-4">
        <span class={`px-3 py-1 rounded-full text-xs font-medium ${categoryColors[category] || 'bg-gray-100 text-gray-700'}`}>
          {category}
        </span>
      </div>
    </div>
  )}
  
  <div class="p-6">
    {!coverImage && (
      <div class="mb-3">
        <span class={`px-3 py-1 rounded-full text-xs font-medium ${categoryColors[category] || 'bg-gray-100 text-gray-700'}`}>
          {category}
        </span>
      </div>
    )}
    
<a href={`/Blog/${slug}`} class="block">
      <h3 class="text-xl font-bold mb-2 text-gray-900 group-hover:text-primary-600 transition-colors">
        {title}
      </h3>
    </a>
    
    <p class="text-gray-500 mb-4 line-clamp-3 text-sm">
      {description}
    </p>
    
    <div class="flex items-center justify-between text-sm border-t border-gray-100 pt-4">
      <time class="text-gray-400">
        {formattedDate}
      </time>
    </div>
    
    {tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="px-2 py-1 bg-gray-100 text-gray-600 text-xs rounded">
            #{tag}
          </span>
        ))}
      </div>
    )}
  </div>
</article>