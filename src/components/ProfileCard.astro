---
// ProfileCard.astro
---

<aside class="sticky top-24 backdrop-blur-md bg-white/70 rounded-3xl p-6 shadow-lg border border-pink-200/30">
  <div class="text-center">
    <!-- Avatar placeholder - ready for anime avatar -->
    <div class="w-32 h-32 mx-auto mb-4 rounded-full bg-gradient-to-br from-pink-200 to-purple-200 flex items-center justify-center overflow-hidden">
      <div class="w-full h-full bg-gradient-to-br from-pink-300 to-purple-300 flex items-center justify-center text-6xl">
        🌸
      </div>
    </div>
    
    <h2 class="text-2xl font-bold mb-2 bg-gradient-to-r from-pink-400 to-purple-400 bg-clip-text text-transparent">
      Your Name
    </h2>
    
    <p class="text-gray-600 text-sm mb-4">
      Anime enthusiast | Tech lover | Creator
    </p>
    
    <div class="border-t border-pink-200/50 pt-4">
      <p class="text-gray-700 text-sm leading-relaxed">
        Welcome to my little corner of the internet! ✨ Here I share my thoughts on tech, anime, and everything in between.
      </p>
    </div>
    
    <!-- Social links placeholder -->
    <div class="mt-6 flex justify-center space-x-4">
      <a href="#" class="w-10 h-10 rounded-full bg-pink-100 hover:bg-pink-200 flex items-center justify-center transition-colors">
        <span class="text-pink-500">𝕏</span>
      </a>
      <a href="#" class="w-10 h-10 rounded-full bg-purple-100 hover:bg-purple-200 flex items-center justify-center transition-colors">
        <span class="text-purple-500">GH</span>
      </a>
      <a href="#" class="w-10 h-10 rounded-full bg-blue-100 hover:bg-blue-200 flex items-center justify-center transition-colors">
        <span class="text-blue-500">✉</span>
      </a>
    </div>
  </div>
</aside>
