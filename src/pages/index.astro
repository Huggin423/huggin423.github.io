---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import PostCard from '@components/PostCard.astro';
import ProfileCard from '@components/ProfileCard.astro';

// Get all blog posts sorted by date
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => 
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<Layout title="Huggin's Tech Nexus - Home">
  <div class="container mx-auto px-6 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main content -->
      <div class="lg:col-span-2">
        <!-- Hero section -->
        <div class="mb-12 backdrop-blur-md bg-cyber-slate/50 p-8 shadow-neon-cyan border border-cyber-cyan/50 animate-fade-in relative overflow-hidden">
          <div class="absolute top-0 right-0 w-20 h-20 border-l-2 border-b-2 border-cyber-purple/30"></div>
          <div class="absolute bottom-0 left-0 w-16 h-16 border-r-2 border-t-2 border-cyber-cyan/30"></div>
          
          <h1 class="text-5xl font-display font-bold mb-4 text-cyber-cyan text-glow-cyan uppercase tracking-wide">
            <span class="text-cyber-purple">⚡</span> Welcome to the Nexus
          </h1>
          <p class="text-gray-300 text-lg leading-relaxed font-mono">
            <span class="text-cyber-cyan">&gt;&gt;</span> Dive into my world of technology, research, and creative projects.
          </p>
        </div>

        <!-- Latest posts -->
        <div class="mb-8">
          <h2 class="text-3xl font-display font-bold mb-6 text-cyber-cyan uppercase tracking-wide border-b-2 border-cyber-purple/50 pb-2">
            <span class="text-cyber-purple">//</span> Latest Posts
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {sortedPosts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                coverImage={post.data.coverImage}
                tags={post.data.tags}
                category={post.data.category}
                slug={post.slug}
              />
            ))}
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <ProfileCard />
      </div>
    </div>
  </div>
</Layout>
