---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import PostCard from '@components/PostCard.astro';
import ProfileCard from '@components/ProfileCard.astro';

export async function getStaticPaths() {
  const categories = ['Paper Notes', 'Tech Talk', 'Fun Products', 'Hobbies'];
  return categories.map(category => ({
    params: { category },
  }));
}

const { category } = Astro.params;

// Get all posts for this category
const allPosts = await getCollection('blog', ({ data }) => {
  return data.category === category;
});

const sortedPosts = allPosts.sort((a, b) => 
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const categoryDescriptions: Record<string, string> = {
  'Paper Notes': '论文笔记与学术洞察',
  'Tech Talk': '技术讨论与编程开发',
  'Fun Products': '有趣的产品与工具',
  'Hobbies': '个人爱好与创意探索',
};
---

<Layout title={`${category} - Huggin's Blog`} description={categoryDescriptions[category!]}>
  <div class="container mx-auto px-6 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main content -->
      <div class="lg:col-span-2">
        <!-- Category header -->
        <div class="mb-12 bg-white border border-gray-200 rounded-lg p-8 shadow-sm">
          <h1 class="text-3xl font-bold mb-4 text-gray-900">
            {category}
          </h1>
          <p class="text-gray-600 text-lg">
            {categoryDescriptions[category!]}
          </p>
          <div class="mt-4 text-sm text-gray-500">
            共 {sortedPosts.length} 篇文章
          </div>
        </div>

        <!-- Posts grid -->
        {sortedPosts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {sortedPosts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                coverImage={post.data.coverImage}
                tags={post.data.tags}
                category={post.data.category}
                slug={post.slug}
              />
            ))}
          </div>
        ) : (
          <div class="bg-gray-50 border border-gray-200 rounded-lg p-12 text-center">
            <p class="text-gray-500 text-lg">
              该分类下暂无文章。
            </p>
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <ProfileCard />
      </div>
    </div>
  </div>
</Layout>