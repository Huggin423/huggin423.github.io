---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const categoryColors: Record<string, string> = {
  'Paper Notes': 'bg-blue-100 text-blue-700',
  'Tech Talk': 'bg-purple-100 text-purple-700',
  'Fun Products': 'bg-pink-100 text-pink-700',
  'Hobbies': 'bg-green-100 text-green-700',
};

const formattedDate = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(entry.data.pubDate);

const baseUrl = import.meta.env.BASE_URL;
---

<Layout title={entry.data.title} description={entry.data.description}>
  <article class="container mx-auto px-6 py-12 max-w-4xl">
    <!-- Cover Image -->
    {entry.data.coverImage && (
      <div class="mb-8 rounded-lg overflow-hidden">
        <img 
          src={entry.data.coverImage} 
          alt={entry.data.title}
          class="w-full h-64 md:h-96 object-cover"
        />
      </div>
    )}

    <!-- Article Header -->
    <div class="bg-white border border-gray-200 rounded-lg p-8 mb-8 shadow-sm">
      <div class="mb-4">
        <span class={`px-3 py-1 rounded-full text-sm font-medium ${categoryColors[entry.data.category] || 'bg-gray-100 text-gray-700'}`}>
          {entry.data.category}
        </span>
      </div>
      
      <h1 class="text-3xl md:text-4xl font-bold mb-4 text-gray-900 leading-tight">
        {entry.data.title}
      </h1>
      
      <div class="flex items-center text-gray-500 mb-6">
        <time class="text-sm">{formattedDate}</time>
      </div>

      <p class="text-lg text-gray-600 leading-relaxed">
        {entry.data.description}
      </p>

      {entry.data.tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {entry.data.tags.map((tag) => (
            <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded text-sm">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </div>

    <!-- Article Content -->
    <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm prose prose-lg max-w-none">
      <Content />
    </div>

    <!-- Back to home link -->
    <div class="mt-8">
      <a 
        href={baseUrl}
        class="text-primary-600 hover:text-primary-700 font-medium"
      >
        ← 返回首页
      </a>
    </div>
  </article>
</Layout>