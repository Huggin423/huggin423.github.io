---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Huggin\'s Tech Nexus - Exploring technology, code, and digital creativity with cyberpunk aesthetics' } = Astro.props;

import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&family=Orbitron:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main class="min-h-screen relative z-10">
      <slot />
    </main>
    <Footer />
  </body>
</html>
